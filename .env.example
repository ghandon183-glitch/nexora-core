# Email notifications for purchase confirmations
# Sign up for a free account at https://resend.com to get an API key.
# No custom domain is required to get started — Resend provides a
# ready-to-use sending address (onboarding@resend.dev) for testing.
RESEND_API_KEY=

# The email address that should receive a notification every time a
# customer clicks "I've completed the payment" at checkout.
NOTIFY_EMAIL=

# Gmail SMTP — used to send a confirmation email to the *customer*.
# Resend's onboarding@resend.dev address can only send to the Resend
# account's own address, so customer-facing email goes through Gmail
# instead until a custom domain is verified with Resend.
# 1. Turn on 2-Step Verification: https://myaccount.google.com/security
# 2. Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# The live site URL, used to build links in customer emails (e.g. to the
# dashboard). Leave blank until the site has a real domain — the email
# still sends fine without it, just without a clickable link.
SITE_URL=
