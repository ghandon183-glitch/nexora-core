# Email notifications for purchase confirmations
# Sign up for a free account at https://resend.com to get an API key.
# No custom domain is required to get started — Resend provides a
# ready-to-use sending address (onboarding@resend.dev) for testing.
RESEND_API_KEY=

# The email address that should receive a notification every time a
# customer clicks "I've completed the payment" at checkout.
NOTIFY_EMAIL=
